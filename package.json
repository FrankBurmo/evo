{
  "name": "evo",
  "version": "1.0.0",
  "description": "Produktene dine vokser kontinuerlig – automatisk.",
  "main": "index.js",
  "scripts": {
    "build:core": "tsc -p packages/core/tsconfig.json",
    "build:server": "tsc -p tsconfig.server.build.json",
    "prepare": "npm run build:core",
    "dev": "tsx server/index.ts",
    "dev:client": "vite",
    "start": "node dist/server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:backend": "vitest run --config vitest.backend.config.ts",
    "test:all": "vitest run && node --experimental-vm-modules node_modules/.bin/vitest run --config vitest.backend.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.frontend.json --noEmit && tsc -p packages/core/tsconfig.json --noEmit && tsc -p packages/cli/tsconfig.json --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FrankBurmo/evo.git"
  },
  "keywords": [],
  "author": "Frank Burmo",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/FrankBurmo/evo/issues"
  },
  "homepage": "https://github.com/FrankBurmo/evo#readme",
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-window": "^1.8.11",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^1.8.8",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "jsdom": "^28.1.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.4"
  }
}

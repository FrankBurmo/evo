{
  "name": "evo",
  "version": "1.0.0",
  "description": "Produktene dine vokser kontinuerlig – automatisk.",
  "main": "index.js",
  "scripts": {
    "dev": "node server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:backend": "node --experimental-vm-modules node_modules/.bin/vitest run --config vitest.backend.config.js",
    "test:all": "vitest run && node --experimental-vm-modules node_modules/.bin/vitest run --config vitest.backend.config.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FrankBurmo/evo.git"
  },
  "keywords": [],

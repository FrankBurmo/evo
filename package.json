  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/FrankBurmo/evo/issues"
  },
  "homepage": "https://github.com/FrankBurmo/evo#readme",
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",

# GitHub Personal Access Token (optional - can be provided via UI)
# Get one from: https://github.com/settings/tokens
# Required scopes: repo
GITHUB_TOKEN=your_github_token_here

# Server port (optional)
PORT=3001

# Allowed CORS origins (comma-separated). Defaults to localhost dev servers.
# In production, set this to your deployed frontend URL(s).
# CORS_ORIGIN=https://frankburmo.github.io,https://your-domain.com

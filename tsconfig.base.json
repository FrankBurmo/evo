{
  // Delt base-konfigurasjon — arves av tsconfig.json, tsconfig.frontend.json
  // og packages/*/tsconfig.json. Inneholder innstillinger som er felles for
  // alle deler av kodebasen.
  "compilerOptions": {
    // ─── Kompilerings-mål ──────────────────────────────────────────────────
    "target": "ES2022",

    // ─── Strenghetsnivå ────────────────────────────────────────────────────
    // strict: true aktiverer strictNullChecks, strictFunctionTypes osv.
    // Hele kodebasen er TypeScript etter H5–H7, så noImplicitAny kan nå være true.
    "strict": true,
    "noImplicitAny": true,

    // ─── Generelt ─────────────────────────────────────────────────────────
    "noEmit": true,

    // ─── Diverse ───────────────────────────────────────────────────────────
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}

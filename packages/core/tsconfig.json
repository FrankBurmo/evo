{
  // packages/core-konfigurasjon — delt analysemotor for server og CLI.
  // Kompilerer index.ts → dist/index.js + dist/index.d.ts
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],

    // ─── Bygg-output ────────────────────────────────────────────────────────
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "declarationDir": "dist"
  },
  "include": ["index.ts"],
  "exclude": ["*.test.ts", "*.spec.ts", "node_modules", "dist"]
}

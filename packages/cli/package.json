{
  "name": "evo-scan",
  "version": "0.1.0",
  "description": "Proaktiv GitHub-repo-analyse og issue-opprettelse – drevet av GitHub Copilot AI",
  "main": "src/index.js",
  "bin": {
    "evo-scan": "./bin/evo-scan.js"
  },
  "scripts": {
    "start": "node bin/evo-scan.js",
    "test": "node --experimental-vm-modules ../../node_modules/.bin/vitest run --config ../../vitest.backend.config.js --include 'packages/cli/**/*.{test,spec}.{js,mjs}'"
  },
  "keywords": [
    "github",
    "copilot",
    "cli",
    "analysis",
    "repository",
    "issues",
    "developer-tools"
  ],
  "author": "Frank Burmo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FrankBurmo/evo.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/FrankBurmo/evo/issues"
  },
  "homepage": "https://github.com/FrankBurmo/evo/tree/main/packages/cli#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "commander": "^13.1.0"
  }
}
